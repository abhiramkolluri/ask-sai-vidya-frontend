{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Amplify Console Hosting",
  "Parameters": {
    "env": {
      "Type": "String"
    },
    "type": {
      "Type": "String"
    }
  },
  "Conditions": {
    "isManual": {
      "Fn::Equals": [
        {
          "Ref": "type"
        },
        "manual"
      ]
    }
  },
  "Resources": {
    "AmplifyBranch": {
      "Type": "AWS::Amplify::Branch",
      "Condition": "isManual",
      "Properties": {
        "BranchName": {
          "Ref": "env"
        },
        "AppId": {
          "Fn::GetAtt": [
            "AmplifyApp",
            "AppId"
          ]
        }
      }
    }
  }
}
